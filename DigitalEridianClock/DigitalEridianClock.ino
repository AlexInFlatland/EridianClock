const unsigned char* const glyphs[] PROGMEM = {glyph0, glyph1, glyph2, glyph3, glyph4, glyph5};

// According to the author, this is how long an Eridian Second is in Earth time.
const unsigned int LENGTH_OF_SECOND_MS = 2366;

// Max value with 5 digits in Base-6 is 7775. Afterwards, the day resets.
const unsigned int LENGTH_OF_FULL_DAY = 7776;

void setup() {
  oled.begin(128, 64, sizeof(tiny4koled_init_128x64br), tiny4koled_init_128x64br);
  oled.setFont(FONT6X8);
  oled.clear();
  oled.on();

  oled.setCursor(28, 0);
  oled.print(F("Eridian Time"));
}

void loop() {
  unsigned long totalEridianSec = millis() / LENGTH_OF_SECOND_MS;
  int clockValue = totalEridianSec % LENGTH_OF_FULL_DAY; 

  int tempValue = clockValue;
  for (int i = 4; i >= 0; i--)
  {
    int digit = tempValue % 6;
    uint8_t xPos = 2 + (i * 25);
    
    // Correct way to read bitmap pointer from PROGMEM
    const unsigned char* bitmapPtr = (const unsigned char*)pgm_read_word(&(glyphs[digit]));
    
    // Draw 24x24 bitmap starting at Page 3 (approx pixel y=24)
    oled.bitmap(xPos, 3, xPos + 24, 3 + 3, bitmapPtr);
    tempValue /= 6;
  }

  delay(LENGTH_OF_SECOND_MS);
}
